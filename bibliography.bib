% =============================================================================
%  SECTION 2 — ENTRY TYPE EXAMPLES
%  Replace these with your actual domain references.
%  The field names and formatting follow the natbib/plainnat conventions.
% =============================================================================

% ---------------------------------------------------------------------------
% @article — journal paper
% Required: author, title, journal, year
% Recommended: volume, number, pages, doi
% ---------------------------------------------------------------------------
@article{ExampleJournalArticle2023,
  author    = {Surname, Firstname and Coauthor, Name},
  title     = {Title of the Journal Article},
  journal   = {Name of the Journal},
  volume    = {42},
  number    = {3},
  pages     = {100--115},
  year      = {2023},
  doi       = {10.XXXX/example.doi}
}

% ---------------------------------------------------------------------------
% @inproceedings — conference paper
% Required: author, title, booktitle, year
% Recommended: pages, doi, address, publisher
% ---------------------------------------------------------------------------
@inproceedings{ExampleConferencePaper2022,
  author    = {Surname, Firstname and Coauthor, Name},
  title     = {Title of the Conference Paper},
  booktitle = {Proceedings of the International Conference on [Topic] (CONF)},
  pages     = {1234--1245},
  year      = {2022},
  doi       = {10.XXXX/example.doi}
}

% ---------------------------------------------------------------------------
% @misc — arXiv preprint
% Use for papers not yet published in a peer-reviewed venue.
% Include howpublished and note fields for clarity.
% ---------------------------------------------------------------------------
@misc{ExampleArxivPreprint2024,
  author        = {Surname, Firstname and Coauthor, Name},
  title         = {Title of the arXiv Preprint},
  howpublished  = {arXiv preprint arXiv:2401.XXXXX},
  year          = {2024},
  doi           = {10.48550/arXiv.2401.XXXXX}
}

% ---------------------------------------------------------------------------
% @phdthesis — doctoral dissertation
% Required: author, title, school, year
% Recommended: type (if not "PhD thesis"), address
% ---------------------------------------------------------------------------
@phdthesis{ExamplePhDThesis2021,
  author  = {Surname, Firstname},
  title   = {Title of the Doctoral Thesis},
  school  = {University Name, Faculty of [Name]},
  year    = {2021}
}

% ---------------------------------------------------------------------------
% @techreport — technical report
% Required: author, title, institution, year
% Recommended: number, type
% ---------------------------------------------------------------------------
@techreport{ExampleTechReport2020,
  author      = {Surname, Firstname and Coauthor, Name},
  title       = {Title of the Technical Report},
  institution = {Research Lab or University Name},
  number      = {TR-2020-01},
  year        = {2020}
}

% ---------------------------------------------------------------------------
% @book — monograph
% Required: author or editor, title, publisher, year
% Recommended: address (publisher city), edition
% ---------------------------------------------------------------------------
@book{ExampleBook2019,
  author    = {Surname, Firstname},
  title     = {Title of the Book},
  publisher = {Publisher Name},
  address   = {City, Country},
  year      = {2019}
}

% ---------------------------------------------------------------------------
% @misc — dataset or software
% Use when citing a dataset release or software package.
% ---------------------------------------------------------------------------
@misc{ExampleDataset2023,
  author       = {{Organisation or Author(s)}},
  title        = {Name of the Dataset or Software},
  howpublished = {\url{https://example.org/dataset}},
  year         = {2023},
  note         = {Accessed: YYYY-MM-DD}
}
