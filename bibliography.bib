% =============================================================================
%  bibliography.bib — SLR Template
%
%  Key convention: FirstAuthorLastnameYearShortTitle
%  e.g., Houlsby2019, McMahan2017, Page2021
%
%  Style: plainnat with natbib [square,sort,comma,numbers]
%  In-text:   \citet{Key}   → Author (Year)
%  Parenthetical: \citep{Key} → (Author, Year)  or  [N] in numbered mode
%
%  -------------------------------------------------------------------------
%  CITATION STYLE QUICK REFERENCE
%  -------------------------------------------------------------------------
%  \citet{A}            Author (Year)
%  \citep{A}            (Author, Year)   — or [N] in numbered mode
%  \citet{A,B}          Author (Year); Author (Year)
%  \citep{A,B}          (Author, Year; Author, Year)
%  \citeauthor{A}       Author              — name only, no year
%  \citeyear{A}         Year               — year only, no name
%  \citep[p.~5]{A}      (Author, Year, p. 5) — with page number
%  -------------------------------------------------------------------------
%
%  ENTRY TYPE EXAMPLES
%  -------------------
%  This file contains:
%  1. All SLR methodology references (keep these — they are universal).
%  2. One example of each common entry type with full field set.
%     Replace or extend with your own domain references.
%
%  Common entry types:
%    @article        — journal paper
%    @inproceedings  — conference paper (preferred over @conference)
%    @techreport     — technical report
%    @misc           — arXiv preprint, software, datasets, web resources
%    @phdthesis      — doctoral thesis
%    @book           — monograph
% =============================================================================


